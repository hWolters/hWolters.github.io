---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE } from '../lib/site';

const projects = [
  ['Sorce', 'https://sorce.io/', 'Algorithms and dashboards that turn physiological and psychological data into actionable insights'],
  ['Kakaokunde', 'https://kakaokunde.vercel.app', 'My personal archive of more than 300 specialty chocolates with ratings and tasting notes'],
  ['Kleinkindabteil Check for Deutsche Bahn', 'https://db-kleinkindabteil-check.vercel.app', 'A tool that finds available seats in toddler compartments on German trains[GERMAN].'],
  ['Flashpanol', 'https://flashpanol.fly.dev', 'A Spanish vocabulary trainer with curated and custom vocabulary lists'],
  ['Café Finance', 'https://medium.com/café-finance', 'An approachable German-language blog about investing and personal finance[GERMAN}]'],
];
const projectsJsonLd = {
  '@context': 'https://schema.org',
  '@graph': projects.map(([name, url, description]) => ({
    '@type': 'CreativeWork',
    name,
    url,
    description,
    creator: { '@type': 'Person', name: SITE.name },
  })),
};
---

<BaseLayout
  title="Projects"
  description="Projects by Heike Terhechte spanning data products, software, language learning, personal finance, and applied analytics."
>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(projectsJsonLd)} />
  <div class="page shell">
    <header class="page-title">
      <h1>Projects</h1>
    </header>

    <div class="project-list">

      <article class="project-entry">
        <h2><a href="https://sorce.io/">Sorce</a></h2>
        <p>Turning physiological data into actionable insights.</p>
        <p>
          Sorce is a US startup founded by an inspiring team of female entrepreneurs. I support the team by developing algorithms and dashboards that transform HRV and psychological data into meaningful insights. From recovery and readiness metrics to team-level analytics, my work helps organizations better understand how their teams are doing.
        </p>
      </article>

      <article class="project-entry">
        <h2><a href="https://kakaokunde.vercel.app">Kakaokunde</a></h2>
        <p>My personal archive of more than 300 specialty chocolates with ratings and tasting notes</p>
        <p>
          I love chocolate and realized that every time I bought a chocolate bar I enjoyed, I forgot what it was a few weeks later. Kakaokunde started as a way to keep track of interesting makers, origins, and tasting notes. Along the way it turned into an excuse to learn more about chocolate, from bean varieties to fermentation, and to build a website around a hobby I genuinely enjoy.
        </p>
      </article>

      <article class="project-entry">
        <h2><a href="https://db-kleinkindabteil-check.vercel.app">Kleinkindabteil Check for Deutsche Bahn</a></h2>
        <pA tool that finds available seats in toddler compartments on German trains[GERMAN]</p>
        <p>
          After traveling with our daughter, I noticed that finding available seats in a German train’s toddler compartment required opening every connection one by one. I built a tool that does the tedious part for you by finding the longest available stretch with free seats, making family travel a little less frustrating.
        </p>
      </article>

      <article class="project-entry">
        <h2><a href="https://flashpanol.fly.dev">Flashpanol</a></h2>
        <p>Spanish vocabulary trainer.</p>
        <p>
          I’ve been learning Spanish for years, but never found a vocabulary app that matched how I wanted to practice. So I built one. Flashpañol focuses on curated vocabulary and the ability to create your my lists.
        </p>
      </article>
      <article class="project-entry">
        <h2><a href="https://medium.com/café-finance">Café Finance</a></h2>
        <p>My blog on investing and personal finance [GERMAN].</p>
        <p>
          Café Finance is my personal finance blog. I started it because I noticed that conversations about investing often happened with my male friends, while many of my female friends felt investing was not really for them. I want to help change that by making financial concepts approachable and free of unnecessary jargon. Finance should feel like something you can read in a café, not something you have to study in a library.
        </p>
      </article>


    </div>

    <section class="academic-section" aria-labelledby="academic-heading">
      <h2 id="academic-heading">Academic Research &amp; Publications</h2>
      <p>
        Before moving into industry, I completed a PhD in customer behavior and predictive analytics. Even during my academic career, I worked closely with companies because I wanted my research to solve real-world problems, not just academic ones. My work focused on customer value prediction models in non-contractual settings resulting in publications in journals including Marketing Science.
      </p>

      <ul class="publication-list">
        <li>
          <a href="https://pubsonline.informs.org/doi/abs/10.1287/mksc.2020.1242">Referral Reward Size and New Customer Profitability</a>
          <span><cite>Marketing Science</cite> (2020)</span>
        </li>
        <li>
          <a href="https://www.emerald.com/jmbr/article-abstract/3/4/335/1328754/Referral-Programs-and-Customer-Value-Insights-from?redirectedFrom=fulltext">Referral Programs and Customer Value: Insights from Two Field Experiments</a>
          <span><cite>Journal of Marketing Behavior</cite> (2018)</span>
        </li>
        <li>
          <a href="https://link.springer.com/chapter/10.1007/978-3-658-29995-8_2">Predictive Customer Analytics</a>
          <span>Book chapter in <cite>Predictive Analytics</cite> (2020)</span>
        </li>
      </ul>
    </section>
  </div>
</BaseLayout>
