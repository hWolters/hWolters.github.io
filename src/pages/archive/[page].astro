---
import type { CollectionEntry } from 'astro:content';
import ArchivePage from '../../components/ArchivePage.astro';
import { ARCHIVE_PAGE_SIZE, getArchivePosts } from '../../lib/archive';

export async function getStaticPaths() {
  const allPosts = await getArchivePosts();
  const totalPages = Math.ceil(allPosts.length / ARCHIVE_PAGE_SIZE);

  return Array.from({ length: Math.max(totalPages - 1, 0) }, (_, index) => {
    const currentPage = index + 2;
    const start = (currentPage - 1) * ARCHIVE_PAGE_SIZE;

    return {
      params: { page: String(currentPage) },
      props: {
        posts: allPosts.slice(start, start + ARCHIVE_PAGE_SIZE),
        currentPage,
        totalPages,
      },
    };
  });
}

interface Props {
  posts: CollectionEntry<'blog'>[];
  currentPage: number;
  totalPages: number;
}

const { posts, currentPage, totalPages } = Astro.props;
---

<ArchivePage posts={posts} currentPage={currentPage} totalPages={totalPages} />
