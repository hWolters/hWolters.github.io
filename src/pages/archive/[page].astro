---
import { ARCHIVE_PAGE_SIZE, getArchivePosts } from '../../lib/archive';

export async function getStaticPaths() {
  const allPosts = await getArchivePosts();
  const totalPages = Math.ceil(allPosts.length / ARCHIVE_PAGE_SIZE);

  return Array.from({ length: Math.max(totalPages - 1, 0) }, (_, index) => {
    const currentPage = index + 2;
    return {
      params: { page: String(currentPage) },
    };
  });
}
const target = '/archive/';
const canonical = new URL(target, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="robots" content="noindex, follow" />
    <meta http-equiv="refresh" content={`0;url=${target}`} />
    <link rel="canonical" href={canonical} />
    <title>Writing archive</title>
  </head>
  <body><a href={target}>Browse all writing</a></body>
</html>
