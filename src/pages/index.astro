---
import BaseLayout from '../layouts/BaseLayout.astro';
import { articlePath, formatDate, SITE } from '../lib/site';
import { getPublicPosts } from '../lib/posts';

const posts = await getPublicPosts();
const latest = posts[0];
const latestPath = articlePath(latest.data.publishDate, latest.data.slug);
const websiteJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: SITE.name,
  url: SITE.url,
  description: SITE.description,
};
---

<BaseLayout>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(websiteJsonLd)} />
  <div class="page shell">
    <section class="latest-section" aria-labelledby="latest-heading">
      <p class="section-label">Latest article</p>
      <article class="latest-article">
      <time datetime={latest.data.publishDate.toISOString()}>{formatDate(latest.data.publishDate)}</time>
      <h1 id="latest-heading">
        <a href={latestPath}>{latest.data.title}</a>
      </h1>
      <p>{latest.data.description}</p>
      <a class="read-more" href={latestPath}>Read more</a>
      </article>
    </section>
  </div>
</BaseLayout>
