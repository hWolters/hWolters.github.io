---
import { getCollection } from 'astro:content';
import PostCard from '../components/PostCard.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { PILLARS, SITE } from '../lib/site';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf(),
);
const featured = posts.filter(({ data }) => data.featured);
const recent = posts.slice(0, 5);
---

<BaseLayout>
  <section class="hero shell">
    <p class="eyebrow">{SITE.name}</p>
    <h1>{SITE.positioning}</h1>
    <p class="hero-intro">
      Essays and practical notes from the intersection of machine learning, data systems, software, and technical leadership.
    </p>
    <div class="button-row">
      <a class="button" href="#selected-writing">Selected writing</a>
      <a class="text-link" href={SITE.github}>Connect on GitHub <span aria-hidden="true">↗</span></a>
    </div>
  </section>

  <section class="section shell" aria-labelledby="expertise-heading">
    <div class="section-heading">
      <p class="eyebrow">Areas of focus</p>
      <h2 id="expertise-heading">From models to systems to teams</h2>
    </div>
    <div class="expertise-grid">
      {Object.values(PILLARS).map((pillar, index) => (
        <article>
          <span class="index" aria-hidden="true">0{index + 1}</span>
          <h3>{pillar.name}</h3>
          <p>{pillar.description}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section section-tinted" id="selected-writing" aria-labelledby="selected-heading">
    <div class="shell">
      <div class="section-heading split-heading">
        <div>
          <p class="eyebrow">Selected writing</p>
          <h2 id="selected-heading">Ideas worth returning to</h2>
        </div>
        <a class="text-link" href="/writing/">View all writing <span aria-hidden="true">→</span></a>
      </div>
      <div class="post-grid">
        {featured.map((post) => <PostCard post={post} />)}
      </div>
    </div>
  </section>

  <section class="section shell" aria-labelledby="recent-heading">
    <div class="section-heading split-heading">
      <div>
        <p class="eyebrow">Archive</p>
        <h2 id="recent-heading">Recent writing</h2>
      </div>
      <a class="text-link" href="/writing/">All articles <span aria-hidden="true">→</span></a>
    </div>
    <div class="post-list">
      {recent.map((post) => <PostCard post={post} compact />)}
    </div>
  </section>

  <section class="section about-callout">
    <div class="shell about-callout-inner">
      <div>
        <p class="eyebrow">About</p>
        <h2>Technical depth with an eye on useful outcomes.</h2>
      </div>
      <div>
        <p>
          I write about what I learn while building data products, software systems, and the teams around them.
        </p>
        <a class="text-link" href="/about/">More about me <span aria-hidden="true">→</span></a>
      </div>
    </div>
  </section>
</BaseLayout>
