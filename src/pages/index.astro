---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { articlePath, formatDate } from '../lib/site';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf(),
);
const latest = posts[0];
const latestPath = articlePath(latest.data.publishDate, latest.data.slug);
---

<BaseLayout description={latest.data.description}>
  <section class="page shell">
    <article class="latest-article">
      <time datetime={latest.data.publishDate.toISOString()}>{formatDate(latest.data.publishDate)}</time>
      <h1>
        <a href={latestPath}>{latest.data.title}</a>
      </h1>
      <p>{latest.data.description}</p>
      <a class="read-more" href={latestPath}>Read more</a>
    </article>
  </section>
</BaseLayout>
