---
import { render, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../../../../layouts/BaseLayout.astro';
import PostCard from '../../../../../components/PostCard.astro';
import { getRelatedPosts } from '../../../../../lib/article-discovery';
import { absoluteUrl, articlePath, formatDate, ogImagePath, SITE } from '../../../../../lib/site';
import { getPublicPosts } from '../../../../../lib/posts';
import { TOPICS, topicArchiveUrl } from '../../../../../lib/topics';

export async function getStaticPaths() {
  const posts = await getPublicPosts();

  return posts.map((post) => {
    const [year, month, day] = post.data.publishDate.toISOString().slice(0, 10).split('-');
    return {
      params: { year, month, day, slug: post.data.slug },
      props: { post },
    };
  });
}

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { Content } = await render(post);
const allPosts = await getPublicPosts();
const relatedPosts = getRelatedPosts(post, allPosts);
const topic = TOPICS[post.data.topic];
const canonicalPath = articlePath(post.data.publishDate, post.data.slug);
const socialImage = post.data.hero?.src ?? ogImagePath(post.data.title);
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.publishDate.toISOString(),
  ...(post.data.updatedDate ? { dateModified: post.data.updatedDate.toISOString() } : {}),
  mainEntityOfPage: absoluteUrl(canonicalPath),
  image: absoluteUrl(socialImage),
  author: {
    '@type': 'Person',
    name: SITE.name,
    url: SITE.url,
    sameAs: SITE.linkedin,
  },
};
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  canonicalPath={canonicalPath}
  type="article"
  image={socialImage}
  publishedTime={post.data.publishDate.toISOString()}
  modifiedTime={post.data.updatedDate?.toISOString()}
>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <article class="article shell">
    <header class="article-header">
      <h1>{post.data.title}</h1>
      <div class="article-meta">
        <time datetime={post.data.publishDate.toISOString()}>{formatDate(post.data.publishDate)}</time>
        <span>By <a href="/">{SITE.name}</a></span>
        <a class="article-topic" href={topicArchiveUrl(post.data.topic)}>{topic.label}</a>
      </div>
    </header>
    <div class="article-content">
      <Content />
    </div>
    <aside class="related-articles" aria-labelledby="related-heading">
      <p class="section-label">Continue reading</p>
      <h2 id="related-heading">Related articles</h2>
      <div class="related-list">
        {relatedPosts.map((relatedPost) => <PostCard post={relatedPost} showDescription={false} />)}
      </div>
    </aside>
  </article>
</BaseLayout>
