---
import { render, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../../../../layouts/BaseLayout.astro';
import { absoluteUrl, articlePath, formatDate, ogImagePath, SITE } from '../../../../../lib/site';
import { getPublicPosts } from '../../../../../lib/posts';

export async function getStaticPaths() {
  const posts = await getPublicPosts();

  return posts.map((post) => {
    const [year, month, day] = post.data.publishDate.toISOString().slice(0, 10).split('-');
    return {
      params: { year, month, day, slug: post.data.slug },
      props: { post },
    };
  });
}

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { Content } = await render(post);
const canonicalPath = articlePath(post.data.publishDate, post.data.slug);
const socialImage = post.data.hero?.src ?? ogImagePath(post.data.title);
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.publishDate.toISOString(),
  ...(post.data.updatedDate ? { dateModified: post.data.updatedDate.toISOString() } : {}),
  mainEntityOfPage: absoluteUrl(canonicalPath),
  image: absoluteUrl(socialImage),
  author: {
    '@type': 'Person',
    name: SITE.name,
    url: `${SITE.url}/about/`,
    sameAs: SITE.linkedin,
  },
};
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  canonicalPath={canonicalPath}
  type="article"
  image={socialImage}
  publishedTime={post.data.publishDate.toISOString()}
  modifiedTime={post.data.updatedDate?.toISOString()}
>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <article class="article shell">
    <header class="article-header">
      <h1>{post.data.title}</h1>
      <div class="article-meta">
        <time datetime={post.data.publishDate.toISOString()}>{formatDate(post.data.publishDate)}</time>
        <span>By <a href="/about/">{SITE.name}</a></span>
      </div>
    </header>
    <div class="article-content">
      <Content />
    </div>
  </article>
</BaseLayout>
