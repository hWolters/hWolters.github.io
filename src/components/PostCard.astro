---
import type { CollectionEntry } from 'astro:content';
import { articlePath, formatDate, PILLARS } from '../lib/site';

interface Props {
  post: CollectionEntry<'blog'>;
  compact?: boolean;
}

const { post, compact = false } = Astro.props;
const href = articlePath(post.data.publishDate, post.data.slug);
---

<article class:list={['post-card', { compact }]}>
  <p class="eyebrow">
    {PILLARS[post.data.pillar].name} · <time datetime={post.data.publishDate.toISOString()}>{formatDate(post.data.publishDate)}</time>
  </p>
  <h3><a href={href}>{post.data.title}</a></h3>
  {!compact && <p class="post-description">{post.data.description}</p>}
</article>
