---
import type { CollectionEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { groupPostsByYear } from '../lib/article-discovery';
import { SITE } from '../lib/site';
import { TOPICS, TOPIC_KEYS } from '../lib/topics';
import PostCard from './PostCard.astro';

interface Props {
  posts: CollectionEntry<'blog'>[];
}

const { posts } = Astro.props;
const groups = groupPostsByYear(posts);
---

<BaseLayout
  title="Writing"
  description={`Browse all articles by ${SITE.name} about engineering leadership, software engineering, data, and AI.`}
>
  <div class="page shell writing-page">
    <header class="writing-header">
      <p class="section-label">Thoughts, lessons, and the occasional rabbit hole</p>
      <h1>Writing</h1>
    </header>

    <nav class="topic-filters" aria-label="Filter articles by topic">
      <button type="button" class="topic-filter" data-topic-filter="all" aria-pressed="true">All</button>
      {TOPIC_KEYS.map((key) => (
        <button type="button" class="topic-filter" data-topic-filter={key} aria-pressed="false">
          {TOPICS[key].shortLabel}
        </button>
      ))}
    </nav>
    <p class="filter-status" aria-live="polite"><span data-result-count>{posts.length}</span> articles</p>

    <div class="writing-timeline">
      {groups.map(({ year, posts: yearPosts }) => (
        <section class="year-group" data-year-group aria-labelledby={`year-${year}`}>
          <h2 id={`year-${year}`}>{year}</h2>
          <div class="archive-list">
            {yearPosts.map((post) => <PostCard post={post} />)}
          </div>
        </section>
      ))}
    </div>
  </div>

  <script>
    const validTopics = new Set(['leadership', 'ai', 'software-engineering', 'data']);
    const buttons = [...document.querySelectorAll<HTMLButtonElement>('[data-topic-filter]')];
    const articles = [...document.querySelectorAll<HTMLElement>('[data-article]')];
    const yearGroups = [...document.querySelectorAll<HTMLElement>('[data-year-group]')];
    const resultCount = document.querySelector<HTMLElement>('[data-result-count]');

    function topicFromUrl() {
      const topic = new URL(window.location.href).searchParams.get('topic');
      return topic && validTopics.has(topic) ? topic : 'all';
    }

    function applyFilter(topic: string, updateHistory = false) {
      let visible = 0;
      for (const article of articles) {
        const matches = topic === 'all' || article.dataset.topic === topic;
        article.hidden = !matches;
        if (matches) visible += 1;
      }
      for (const group of yearGroups) {
        group.hidden = !group.querySelector('[data-article]:not([hidden])');
      }
      for (const button of buttons) {
        button.setAttribute('aria-pressed', String(button.dataset.topicFilter === topic));
      }
      if (resultCount) resultCount.textContent = String(visible);

      if (updateHistory) {
        const url = new URL(window.location.href);
        if (topic === 'all') url.searchParams.delete('topic');
        else url.searchParams.set('topic', topic);
        window.history.pushState({}, '', `${url.pathname}${url.search}${url.hash}`);
      }
    }

    for (const button of buttons) {
      button.addEventListener('click', () => applyFilter(button.dataset.topicFilter ?? 'all', true));
    }
    window.addEventListener('popstate', () => applyFilter(topicFromUrl()));
    applyFilter(topicFromUrl());
  </script>
</BaseLayout>
