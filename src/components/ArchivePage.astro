---
import type { CollectionEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { groupPostsByYear } from '../lib/article-discovery';
import { SITE } from '../lib/site';
import { TOPICS, TOPIC_KEYS, topicArchiveUrl, type Topic } from '../lib/topics';
import PostCard from './PostCard.astro';

interface Props {
  posts: CollectionEntry<'blog'>[];
  activeTopic?: Topic;
}

const { posts, activeTopic } = Astro.props;
const currentTopic = activeTopic ? TOPICS[activeTopic] : undefined;
const groups = groupPostsByYear(posts);
const title = currentTopic ? `${currentTopic.label} Articles` : 'Writing';
const description = currentTopic
  ? currentTopic.seoDescription
  : `Browse articles by ${SITE.name} on engineering leadership, AI, software engineering, data, and product work.`;
const canonicalPath = activeTopic ? topicArchiveUrl(activeTopic) : '/archive/';
---

<BaseLayout
  title={title}
  description={description}
  canonicalPath={canonicalPath}
>
  <div class="page shell writing-page">
    <header class="writing-header">
      <p class="section-label">Thoughts, lessons, and the occasional rabbit hole</p>
      <h1>{currentTopic ? currentTopic.label : 'Writing'}</h1>
      {currentTopic && <p>{currentTopic.description}</p>}
    </header>

    <nav class="topic-filters" aria-label="Filter articles by topic">
      <a class="topic-filter" href="/archive/" aria-current={!activeTopic ? 'page' : undefined}>All</a>
      {TOPIC_KEYS.map((key) => (
        <a class="topic-filter" href={topicArchiveUrl(key)} aria-current={activeTopic === key ? 'page' : undefined}>
          {TOPICS[key].shortLabel}
        </a>
      ))}
    </nav>
    <p class="filter-status">{posts.length} articles</p>

    <div class="writing-timeline">
      {groups.map(({ year, posts: yearPosts }) => (
        <section class="year-group" data-year-group aria-labelledby={`year-${year}`}>
          <h2 id={`year-${year}`}>{year}</h2>
          <div class="archive-list">
            {yearPosts.map((post) => <PostCard post={post} />)}
          </div>
        </section>
      ))}
    </div>
  </div>
</BaseLayout>
